{
  "Postgres": {
    "ConnectionString": "Host=localhost;Port=5432;Database=documind;Username=postgres;Password=<password>",
    "Schema": "public"
  },
  "OpenAI": {
    "Endpoint": "https://api.openai.com/v1/",
    "ChatModel": "gpt-4.1-mini",
    "EmbeddingModel": "text-embedding-3-small"
  },
  "LocalStorage": {
    "BasePath": "storage",
    "UploadsPath": "uploads",
    "ProcessedPath": "processed"
  },
  "Ingestion": {
    "ChunkSize": 1200,
    "ChunkOverlap": 200,
    "MaxFileSizeMb": 25,
    "AllowedExtensions": [ ".pdf", ".md", ".txt" ]
  },
  "Query": {
    "TopK": 5,
    "MinScore": 0.7,
    "MaxContextChunks": 8
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
